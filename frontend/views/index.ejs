

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/videocam.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="icon" href="/favicon.png" type="image/x-icon">
    <title>SAMS</title>
    <script defer src="/face-api.min.js"></script>
    <script defer src="/script.js"></script>
    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            background: #f5f5f5;
        }
        .content-growth-spacer { flex: 1 0 auto; }
        #status {
            min-height: 70px;
            transition: all 0.3s ease;
        }
        
        /* Premium theme color matching your new header code */
        #viewLogButton {
            background: linear-gradient(135deg, #0f172a 0%, #1e40af 100%);
            color: #ffffff;
            border: 1px solid rgba(255, 255, 255, 0.08);
            font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
            font-weight: 600;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
            transition: all 0.3s ease;
        }
        #viewLogButton:hover {
            opacity: 0.95;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(15, 23, 42, 0.2);
        }
    </style>
</head>
<body>
    <%- include("partials/header") %>

    <div class="content-growth-spacer">
        <br><br>
        <div class="videoPlayer">
            <video id="videoCam"></video>
            <br><br>
            <div class="buttons">
                <button id="startButton">START</button>
                <button id="viewLogButton">View Attendance Log</button>
            </div>
        </div>

        <div class="displayStudentRecognised">
            <br>
            <h1 id="status">Loading...</h1>
            <h3 id="studentName"></h3>
            <h5 id="dateTime"></h5>
            <img id="studentImg" />
            <br><br>
            <button id="confirmButton">CONFIRM ATTENDANCE</button>
        </div>
    </div>

    <%- include("partials/footer") %>

    <div id="popupWindowOverlay">
        <div id="popup">
            <div class="popupHeader">
                <h2>Attendance Log</h2>
            </div>
            <div class="popupContent">
                <table id="attendanceTable" class="styled-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Time</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="closeButton">
                <button id="closePopup">CLOSE</button>
            </div>
        </div>
    </div>
</body>
</html>