<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Database - SAMS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style>
    body {
      background-color: #f8fafc;
      background-image: 
        radial-gradient(at 100% 0%, rgba(37, 99, 235, 0.03) 0px, transparent 50%),
        radial-gradient(at 0% 100%, rgba(15, 23, 42, 0.02) 0px, transparent 50%);
      background-attachment: fixed;
      color: #334155;
      font-family: 'Plus Jakarta Sans', sans-serif;
      letter-spacing: -0.01em;
    }

    .page-wrapper {
      display: grid;
      grid-template-rows: auto 1fr auto;
      min-height: 100vh;
    }

    .tracking-wider-custom {
      letter-spacing: 0.06em;
      font-size: 0.75rem;
    }
    
    .premium-badge {
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      font-weight: 700;
      padding: 6px 14px;
      border-radius: 8px;
    }

    /* Structural Interactive Student Framework Card */
    .premium-student-card {
      background: #ffffff;
      border: 1px solid #e2e8f0 !important;
      border-radius: 20px !important;
      overflow: hidden;
      transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .premium-student-card:hover {
      transform: translateY(-8px);
      border-color: #3b82f6 !important;
      box-shadow: 0 20px 25px -5px rgba(59, 130, 246, 0.08), 0 10px 10px -5px rgba(59, 130, 246, 0.04) !important;
    }

    /* Biometric Viewport Mask Layer */
    .image-frame {
      background-color: #f1f5f9;
      width: 100%;
      height: 260px;
      overflow: hidden;
      position: relative;
    }
    
    .image-frame img {
      transition: transform 0.5s ease;
    }
    
    /* Subtle Targeting Scanner Overlay Simulation */
    .image-frame::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: linear-gradient(180deg, transparent 50%, rgba(15, 23, 42, 0.5) 100%);
      opacity: 0.7;
      transition: opacity 0.3s ease;
    }

    .premium-student-card:hover .image-frame img {
      transform: scale(1.06);
    }

    .premium-student-card:hover .image-frame::after {
      opacity: 0.85;
    }

    /* Button Interface Guidelines */
    .btn-premium-primary {
      background: #2563eb;
      color: #ffffff;
      border: none;
      box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
      transition: all 0.2s ease;
    }
    .btn-premium-primary:hover {
      background: #1d4ed8;
      color: #ffffff;
      box-shadow: 0 6px 20px rgba(37, 99, 235, 0.25);
    }
    
    .btn-parameter-link {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      color: #475569;
      transition: all 0.25s ease;
    }
    
    .premium-student-card:hover .btn-parameter-link {
      background: #2563eb;
      border-color: #2563eb;
      color: #ffffff;
      box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
    }
    
    .panel-container-blur {
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(12px);
      border: 1px solid #e2e8f0 !important;
    }
  </style>
</head>
<body>

  <div class="page-wrapper">
    
    <%- include("partials/header") %>

    <main class="container my-5 py-2" style="max-width: 1200px;">
      
      <div class="p-4 rounded-4 mb-5 d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 panel-container-blur">
        <div>
          <span class="badge bg-primary bg-opacity-10 text-primary mb-2 premium-badge border border-primary border-opacity-10">Verification Registry</span>
          <h2 class="fw-extrabold text-dark tracking-tight m-0" style="font-size: 1.6rem; letter-spacing: -0.03em;">
            Student Registry Database
          </h2>
          <p class="text-muted small mb-0 mt-1">Overview of verified baseline biometric profiles compiled within the local cluster ecosystem.</p>
        </div>
      </div>

      <% if (students.length === 0) { %>
        <div class="text-center p-5 bg-white rounded-4 border my-5 shadow-sm" style="border-color: #e2e8f0 !important;">
          <div class="bg-light text-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
            <i class="fa-solid fa-fingerprint fs-3 text-muted opacity-75"></i>
          </div>
          <h5 class="fw-bold text-dark mb-2">No Profiles Located</h5>
          <p class="text-muted small mx-auto mb-4" style="max-width: 420px; line-height: 1.6;">
            There are currently no active biometric student feature vectors serialized inside this local cluster space.
          </p>
          <a href="/login" class="btn btn-premium-primary btn-sm px-4 py-2 rounded-3 fw-semibold shadow-sm">
            Initialize Enrollment Panel
          </a>
        </div>
      <% } else { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
          <% students.forEach(student => { %>
            <div class="col">
              <div class="card h-100 premium-student-card shadow-sm">
                
                <div class="image-frame">
                  <img src="<%= student.photo ? '/uploaded-photos/' + student.photo : '/fallback.png' %>" 
                       class="w-100 h-100" 
                       style="object-fit: cover;" 
                       alt="<%= student.name %>">
                </div>
                
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                  <div class="mb-4">
                    <h6 class="fw-bold text-dark text-truncate mb-2" title="<%= student.name %>" style="letter-spacing: -0.01em; font-size: 1.05rem;">
                      <%= student.name %>
                    </h6>
                    <div class="d-flex flex-column gap-2 mt-2">
                      <span class="text-secondary small d-inline-flex align-items-center gap-2 text-truncate w-100" style="font-size: 0.8rem;">
                        <i class="fa-solid fa-graduation-cap text-muted opacity-70 small"></i> <%= student.course || "B.Tech CSE" %>
                      </span>
                      <span class="text-muted small d-inline-flex align-items-center gap-2 text-truncate w-100" style="font-size: 0.75rem; letter-spacing: 0.02em;">
                        <i class="fa-solid fa-fingerprint text-muted opacity-70 small"></i> ID: <%= student.rollNumber || "N/A" %>
                      </span>
                    </div>
                  </div>
                  
                  <div class="pt-1">
                    <a href="/profile/<%= student._id %>" class="btn btn-parameter-link w-100 btn-sm py-2.5 rounded-3 fw-semibold d-flex align-items-center justify-content-center gap-2">
                      <i class="fa-regular fa-address-card small"></i> View Profile Data
                    </a>
                  </div>
                </div>

              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    </main>

    <%- include("partials/footer") %>

  </div>

</body>
</html>