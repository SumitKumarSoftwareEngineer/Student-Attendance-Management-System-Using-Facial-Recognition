<%- include("partials/header") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
  /* Page specific resets to ensure perfect vertical alignment layout */
  .login-wrapper {
    font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    min-height: calc(100vh - 70px) !important;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1rem;
    box-sizing: border-box;
  }
  .login-card {
    border: none !important;
    border-radius: 16px !important;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08) !important;
    background: #ffffff;
    width: 100%;
    max-width: 420px;
    overflow: hidden;
  }
  .login-input-group {
    display: flex;
    align-items: center;
  }
  .login-input-group .input-group-text {
    background-color: #f8f9fa !important;
    border-right: none !important;
    color: #6c757d;
  }
  .login-input-group .form-control {
    border-left: none !important;
    background-color: #f8f9fa !important;
  }
  .login-input-group .form-control:focus {
    background-color: #f8f9fa !important;
    box-shadow: none !important;
    border-color: #dee2e6 !important;
  }
  .btn-submit {
    background: linear-gradient(135deg, #0f172a 0%, #1e40af 100%) !important;
    color: #ffffff !important;
    border: none !important;
    padding: 12px !important;
    font-weight: 600 !important;
    border-radius: 8px !important;
    transition: all 0.2s ease-in-out !important;
  }
  .btn-submit:hover {
    opacity: 0.95;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(30, 64, 175, 0.2) !important;
  }
</style>

<div class="login-wrapper">
  <div class="login-card">
    <div class="card-body p-4 p-sm-5">
      
      <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center bg-dark text-white rounded-circle mb-3 shadow-sm" style="width: 56px; height: 56px;">
          <i class="fa-solid fa-lock fs-5"></i>
        </div>
        <h3 class="fw-bold text-dark mb-1" style="letter-spacing: -0.5px;">Welcome Back</h3>
        <p class="text-muted small">Sign in to access your SAMS dashboard</p>
      </div>
      
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger d-flex align-items-center rounded-3 border-0 small py-2.5 mb-4" role="alert">
          <i class="fa-solid fa-triangle-exclamation me-2 flex-shrink-0"></i>
          <div class="fw-medium"><%= error %></div>
        </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label fw-semibold text-secondary small mb-1">Username</label>
          <div class="input-group login-input-group">
            <span class="input-group-text px-3"><i class="fa-solid fa-user small"></i></span>
            <input type="text" name="username" class="form-control ps-0" placeholder="Enter username" required>
          </div>
        </div>
        
        <div class="mb-4">
          <label class="form-label fw-semibold text-secondary small mb-1">Password</label>
          <div class="input-group login-input-group">
            <span class="input-group-text px-3"><i class="fa-solid fa-key small"></i></span>
            <input type="password" name="password" class="form-control ps-0" placeholder="••••••••" required>
          </div>
        </div>
        
        <button type="submit" class="btn btn-submit w-100 d-flex align-items-center justify-content-center gap-2">
          Sign In <i class="fa-solid fa-arrow-right small"></i>
        </button>
      </form>

      <div class="position-relative my-4 text-center">
        <hr class="text-muted opacity-25 m-0">
        <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small tracking-wider text-uppercase" style="font-size: 0.68rem; font-weight: 700;">Demo Access</span>
      </div>
      
      <div class="bg-light border border-secondary border-opacity-10 rounded-3 p-3">
        <div class="d-flex flex-column gap-2 small">
          <div class="d-flex justify-content-between align-items-center">
            <span class="text-secondary fw-medium"><i class="fa-solid fa-user-gear me-1 text-muted"></i> Admin:</span>
            <code class="bg-white border px-2 py-0.5 rounded text-danger fw-semibold" style="font-size: 0.8rem;">admin / admin</code>
          </div>
          <div class="d-flex justify-content-between align-items-center">
            <span class="text-secondary fw-medium"><i class="fa-solid fa-chalkboard-user me-1 text-muted"></i> Faculty:</span>
            <code class="bg-white border px-2 py-0.5 rounded text-primary fw-semibold" style="font-size: 0.8rem;">faculty / faculty</code>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<%- include("partials/footer") %>