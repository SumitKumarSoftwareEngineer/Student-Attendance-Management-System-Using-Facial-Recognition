<%- include("partials/header") %>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  .login-wrapper {
    font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: #f8fafc;
    background-image: 
      radial-gradient(at 0% 0%, rgba(37, 99, 235, 0.03) 0px, transparent 50%),
      radial-gradient(at 100% 100%, rgba(15, 23, 42, 0.02) 0px, transparent 50%);
    min-height: calc(100vh - 70px) !important;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1rem;
    box-sizing: border-box;
  }
  
  .login-card {
    border: 1px solid rgba(226, 232, 240, 0.8) !important;
    border-radius: 20px !important;
    box-shadow: 0 20px 25px -5px rgba(15, 23, 42, 0.03), 0 10px 10px -5px rgba(15, 23, 42, 0.02) !important;
    background: #ffffff;
    width: 100%;
    max-width: 440px;
    overflow: hidden;
  }

  .login-input-group {
    display: flex;
    align-items: center;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    background-color: #ffffff;
    transition: all 0.2s ease-in-out;
  }

  .login-input-group:focus-within {
    border-color: #2563eb !important;
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1) !important;
  }

  .login-input-group .input-group-text {
    background-color: transparent !important;
    border: none !important;
    color: #94a3b8;
    padding-left: 1rem;
    padding-right: 0.5rem;
    transition: color 0.2s ease;
  }

  .login-input-group:focus-within .input-group-text {
    color: #2563eb;
  }

  .login-input-group .form-control {
    border: none !important;
    background-color: transparent !important;
    padding: 11px 12px 11px 4px;
    color: #1e293b;
    font-size: 0.95rem;
  }

  .login-input-group .form-control:focus {
    box-shadow: none !important;
    outline: none !important;
  }

  .form-label-custom {
    color: #475569;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .btn-submit {
    background: #2563eb !important;
    color: #ffffff !important;
    border: none !important;
    padding: 13px !important;
    font-weight: 600 !important;
    font-size: 0.95rem;
    border-radius: 10px !important;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15) !important;
  }

  .btn-submit:hover {
    background: #1d4ed8 !important;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.25) !important;
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  .system-badge {
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 8px;
    display: inline-block;
  }
</style>

<div class="login-wrapper">
  <div class="login-card">
    <div class="card-body p-4 p-sm-5">
      
      <div class="text-center mb-4">
        <span class="badge bg-primary bg-opacity-10 text-primary mb-3 system-badge border border-primary border-opacity-10">
          Secure Portal
        </span>
        <h3 class="fw-extrabold text-dark mb-1" style="letter-spacing: -0.02em; font-size: 1.6rem;">
          Account Authentication
        </h3>
        <p class="text-muted small mb-0">Provide credentials to access your centralized SAMS system panel.</p>
      </div>
      
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger d-flex align-items-center rounded-3 border-0 small py-3 mb-4" role="alert" style="background-color: #fef2f2; color: #991b1b;">
          <i class="fa-solid fa-triangle-exclamation me-2 flex-shrink-0" style="color: #dc2626;"></i>
          <div class="fw-semibold"><%= error %></div>
        </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label-custom">Username</label>
          <div class="login-input-group">
            <span class="input-group-text"><i class="fa-solid fa-user small"></i></span>
            <input type="text" name="username" class="form-control" placeholder="Enter security username" autocomplete="username" required>
          </div>
        </div>
        
        <div class="mb-4">
          <label class="form-label-custom">Password</label>
          <div class="login-input-group">
            <span class="input-group-text"><i class="fa-solid fa-key small"></i></span>
            <input type="password" name="password" class="form-control" placeholder="••••••••" autocomplete="current-password" required>
          </div>
        </div>
        
        <button type="submit" class="btn btn-submit w-100 d-flex align-items-center justify-content-center gap-2">
          Secure Sign In <i class="fa-solid fa-arrow-right small"></i>
        </button>
      </form>

    </div>
  </div>
</div>

<%- include("partials/footer") %>