<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Attendance Ledger - Smart Student Attendance Management System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style>
    body {
      background-color: #f6f8fa;
      color: #2D3748;
      font-family: 'Plus Jakarta Sans', sans-serif;
      letter-spacing: -0.01em;
    }

    .premium-title-card {
      background: radial-gradient(circle at top right, #1e40af 0%, #0f172a 100%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      color: #ffffff !important;
    }

    .premium-card {
      background: #ffffff;
      border: 1px solid rgba(226, 232, 240, 0.8) !important;
      border-radius: 20px !important;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.01), 0 2px 4px -1px rgba(0, 0, 0, 0.01);
    }

    .premium-label {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #64748b;
      margin-bottom: 6px;
      display: block;
    }

    .premium-form-control {
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      font-size: 0.88rem;
      padding: 10px 14px;
      color: #1e293b;
      transition: all 0.2s ease;
    }
    .premium-form-control:focus {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
      outline: none;
    }

    .btn-premium-primary {
      background: #2563eb;
      color: #ffffff;
      border: none;
      padding: 11px 20px;
      font-size: 0.88rem;
      font-weight: 600;
      border-radius: 10px;
      box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
      transition: all 0.2s ease;
    }
    .btn-premium-primary:hover {
      background: #1d4ed8;
      color: #ffffff;
    }

    .btn-premium-reset, .btn-premium-csv {
      padding: 11px 20px;
      font-size: 0.88rem;
      font-weight: 600;
      border-radius: 10px;
    }

    .custom-table th {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #475569;
      padding: 16px 20px;
    }
    .custom-table td {
      padding: 16px 20px;
      font-size: 0.9rem;
      color: #334155;
    }

    .status-badge {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      padding: 6px 14px;
      border-radius: 8px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
  </style>
</head>
<body>

<%- include("partials/header") %>

<div class="page-wrapper">
  <main class="container my-5" style="max-width: 1180px;">
    
    <div class="p-4 p-md-5 rounded-4 shadow-sm premium-title-card mb-4 d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3">
      <div>
        <span class="badge bg-blue bg-opacity-20 text-info text-uppercase mb-2 font-weight-bold" style="font-size: 0.68rem; letter-spacing: 0.05em; padding: 5px 10px; border-radius: 6px; border: 1px solid rgba(0,220,255,0.15);">System Ledger</span>
        <h1 class="h3 fw-extrabold mb-1 text-white tracking-tight">
          Attendance Ledger History
        </h1>
        <p class="text-white text-opacity-75 small mb-0 lh-base">Review cryptographically timestamped records, sort queries, and compile telemetry matrices.</p>
      </div>
      <div>
        <span class="badge bg-white text-dark border-0 px-3 py-2 rounded-3 fw-bold small shadow-sm d-inline-flex align-items-center gap-2">
          <i class="fa-solid fa-database text-primary small"></i> Total Log Entries: <%= logs ? logs.length : 0 %>
        </span>
      </div>
    </div>

    <div class="card premium-card shadow-sm p-4 mb-4">
      <form method="GET" action="/attendance-log" class="row g-3 align-items-end">
        <div class="col-md-1 col-4">
          <label class="premium-label">Day</label>
          <input type="number" name="day" class="form-control premium-form-control" min="1" max="31" placeholder="DD" value="<%= filters ? filters.day : '' %>">
        </div>

        <div class="col-md-1 col-4">
          <label class="premium-label">Month</label>
          <input type="number" name="month" class="form-control premium-form-control" min="1" max="12" placeholder="MM" value="<%= filters ? filters.month : '' %>">
        </div>

        <div class="col-md-2 col-4">
          <label class="premium-label">Year</label>
          <input type="number" name="year" class="form-control premium-form-control" min="2000" max="2100" placeholder="YYYY" value="<%= filters ? filters.year : '' %>">
        </div>

        <div class="col-md-3">
          <label class="premium-label">Student Reference</label>
          <input type="text" name="studentName" class="form-control premium-form-control" placeholder="Search by name..." value="<%= filters ? filters.studentName : '' %>">
        </div>

        <div class="col-md-2">
          <label class="premium-label">Branch</label>
          <input type="text" name="branch" class="form-control premium-form-control" placeholder="e.g. CSE" value="<%= filters ? filters.branch : '' %>">
        </div>

        <div class="col-md-2">
          <label class="premium-label">Semester</label>
          <input type="text" name="semester" class="form-control premium-form-control" placeholder="e.g. 6" value="<%= filters ? filters.semester : '' %>">
        </div>

        <div class="col-md-3 d-flex gap-2 align-items-end">
          <button type="submit" class="btn btn-premium-primary flex-grow-1">
            <i class="fa-solid fa-filter me-1"></i> Filter
          </button>
          <a href="/attendance-log" class="btn btn-premium-reset">Clear</a>
        </div>
      </form>

      <div class="mt-4 pt-3 border-top">
        <a href="/attendance-log/download/csv?day=<%= filters.day || '' %>&month=<%= filters.month || '' %>&year=<%= filters.year || '' %>&studentName=<%= encodeURIComponent(filters.studentName || '') %>&branch=<%= encodeURIComponent(filters.branch || '') %>&semester=<%= encodeURIComponent(filters.semester || '') %>"
           class="btn btn-premium-csv d-inline-flex align-items-center">
          <i class="fa-solid fa-file-arrow-down me-2"></i>Export Structured CSV
        </a>
      </div>
    </div>

    <div class="card premium-card shadow-sm overflow-hidden">
      <div class="table-responsive">
        <table class="table custom-table mb-0">
          <thead>
            <tr>
              <th>Student Name</th>
              <th>Branch</th>
              <th>Semester</th>
              <th>Status</th>
              <th>Timestamp</th>
            </tr>
          </thead>
          <tbody>
            <% if (logs && logs.length) { %>
              <% logs.forEach(log => { %>
                <tr>
                  <td class="fw-bold"><%= log.studentName %></td>
                  <td><%= log.branch || '—' %></td>
                  <td><%= log.semester || '—' %></td>
                  <td>
                    <% if (log.status && log.status.toLowerCase() === 'present') { %>
                      <span class="status-badge bg-success bg-opacity-10 text-success">Present</span>
                    <% } else { %>
                      <span class="status-badge bg-primary bg-opacity-10 text-primary"><%= log.status || 'Verified' %></span>
                    <% } %>
                  </td>
                  <td><%= new Date(log.date).toLocaleString() %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center py-5 text-muted">No records found</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>

  <%- include("partials/footer") %>
</div>
</body>
</html>